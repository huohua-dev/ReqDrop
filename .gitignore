# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Superpowers process artifacts (specs, plans) — keep local, not tracked
docs/superpowers/

# Gradle
.gradle/
build/
# The Gradle wrapper jar MUST be tracked despite the *.jar rule above.
!gradle/wrapper/gradle-wrapper.jar
